# Prediction-market bot configuration
PAPER_INITIAL_BALANCE=100
# Use coinbase + BTC/USD if Binance returns HTTP 451 (geo-restricted)
SYMBOL=BTC/USD
DATA_PROVIDER=coinbase
DATABASE_URL=sqlite:///./paper_trading.db
LOOP_INTERVAL_SECONDS=10
TIMEFRAME=15m

# Edge engine
MIN_EDGE=0.08
# Fallback only when Kalshi asks are unavailable (0.50 = 50¢ YES)
MARKET_PROB_ABOVE=0.50
CONTRACT_COST=0.50
# Face value per bet ($5 face ⇒ 5 contracts that pay $1 each if correct)
STAKE_NOTIONAL=5
AUTO_BET=true
MIN_SECONDS_TO_BET=20

# Strike / odds source: kalshi (default) pulls KXBTC15M from Kalshi public API
STRIKE_SOURCE=kalshi
KALSHI_SERIES=KXBTC15M

# Set true once to wipe paper W/L and reset bankroll, then set back to false
# RESET_PAPER_HISTORY=true
# Or run: python main.py --reset-paper

# Optional manual overrides (beat Kalshi when set)
# MANUAL_STRIKE=64737.27
# MARKET_CENTS=55
# MANUAL_STRIKE_FILE=manual_strike.txt
# MARKET_CENTS_FILE=market_cents.txt

# Logging (terminal output is also written here)
LOG_DIR=logs
LOG_FILE=bot.log
# Rotate when bot.log exceeds this size (bytes); keep N backups
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=5

# Optional: exchange API credentials (not required for public market data)
# API_KEY=
# API_SECRET=
