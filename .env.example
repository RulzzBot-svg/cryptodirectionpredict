# Prediction-market bot configuration
PAPER_INITIAL_BALANCE=10000
# Use coinbase + BTC/USD if Binance returns HTTP 451 (geo-restricted)
SYMBOL=BTC/USD
DATA_PROVIDER=coinbase
DATABASE_URL=sqlite:///./paper_trading.db
LOOP_INTERVAL_SECONDS=10
TIMEFRAME=15m

# Edge engine
MIN_EDGE=0.08
MARKET_PROB_ABOVE=0.50
CONTRACT_COST=0.50
STAKE_NOTIONAL=20
AUTO_BET=true
MIN_SECONDS_TO_BET=20

# Strike / odds source: kalshi (default) pulls KXBTC15M from Kalshi public API
STRIKE_SOURCE=kalshi
KALSHI_SERIES=KXBTC15M

# Optional manual overrides (beat Kalshi when set)
# MANUAL_STRIKE=64737.27
# MARKET_CENTS=55
# MANUAL_STRIKE_FILE=manual_strike.txt
# MARKET_CENTS_FILE=market_cents.txt

# Optional: exchange API credentials (not required for public market data)
# API_KEY=
# API_SECRET=
